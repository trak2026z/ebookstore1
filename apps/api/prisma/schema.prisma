generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum BookStatus {
  DRAFT
  PUBLISHED
  WITHDRAWN
}

enum BookFormat {
  PDF
  EPUB
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(255)
  displayName  String?  @db.VarChar(120)
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model SystemMetadata {
  key       String   @id @db.VarChar(100)
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_metadata")
}

model Author {
  id String @id @default(uuid()) @db.Uuid

  /// Retained temporarily while older write paths are migrated.
  name        String  @db.VarChar(160)
  displayName String  @db.VarChar(160)
  firstName   String? @db.VarChar(80)
  lastName    String? @db.VarChar(100)
  biography   String?

  slug      String       @unique @db.VarChar(180)
  books     BookAuthor[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([name], map: "authors_name_idx")
  @@index([displayName], map: "authors_display_name_idx")
  @@map("authors")
}

model Category {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(120)
  slug        String         @unique @db.VarChar(140)
  description String?
  books       BookCategory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("categories")
}

model Book {
  id          String     @id @default(uuid()) @db.Uuid
  title       String     @db.VarChar(240)
  slug        String     @unique @db.VarChar(260)
  isbn        String     @unique @db.VarChar(40)
  description String
  priceMinor  Int
  currency    String     @default("PLN") @db.Char(3)
  status      BookStatus @default(DRAFT)
  format      BookFormat @default(PDF)
  coverKey    String?    @db.VarChar(512)

  /// Retained temporarily for backward compatibility with the public catalog API.
  coverUrl    String?
  publishedAt DateTime?
  authors     BookAuthor[]
  categories  BookCategory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, createdAt(sort: Desc), id], map: "books_status_created_at_id_idx")
  @@map("books")
}

model BookAuthor {
  bookId   String @db.Uuid
  authorId String @db.Uuid
  position Int    @default(0)

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@id([bookId, authorId])
  @@index([authorId, bookId], map: "book_authors_author_id_book_id_idx")
  @@index([bookId, position, authorId], map: "book_authors_book_id_position_author_id_idx")
  @@map("book_authors")
}

model BookCategory {
  bookId     String @db.Uuid
  categoryId String @db.Uuid
  position   Int    @default(0)

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([bookId, categoryId])
  @@index([categoryId, bookId], map: "book_categories_category_id_book_id_idx")
  @@index([bookId, position, categoryId], map: "book_categories_book_id_position_category_id_idx")
  @@map("book_categories")
}
