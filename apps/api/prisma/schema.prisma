generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum BookStatus {
  DRAFT
  PUBLISHED
  WITHDRAWN
}

enum BookFormat {
  PDF
  EPUB
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(255)
  displayName  String?  @db.VarChar(120)
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model SystemMetadata {
  key       String   @id @db.VarChar(100)
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_metadata")
}

model Author {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(160)
  slug      String   @unique @db.VarChar(180)
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name], map: "authors_name_idx")
  @@map("authors")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(140)
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Book {
  id          String     @id @default(uuid()) @db.Uuid
  title       String     @db.VarChar(240)
  slug        String     @unique @db.VarChar(260)
  isbn        String     @unique @db.VarChar(40)
  description String
  priceMinor  Int
  currency    String     @default("PLN") @db.Char(3)
  status      BookStatus @default(DRAFT)
  format      BookFormat @default(PDF)
  coverKey    String?    @db.VarChar(512)

  /// Retained temporarily for backward compatibility with the public catalog API.
  coverUrl    String?
  publishedAt DateTime?
  authorId    String    @db.Uuid
  categoryId  String    @db.Uuid
  author      Author    @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([categoryId, status], map: "books_category_status_idx")
  @@index([status, createdAt(sort: Desc), id], map: "books_status_created_at_id_idx")
  @@index([authorId, status, createdAt(sort: Desc), id], map: "books_author_status_created_at_id_idx")
  @@map("books")
}
