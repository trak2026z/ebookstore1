generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(255)
  displayName  String?  @db.VarChar(120)
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model SystemMetadata {
  key       String   @id @db.VarChar(100)
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_metadata")
}

model Author {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(160)
  slug      String   @unique @db.VarChar(180)
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name], map: "authors_name_idx")
  @@map("authors")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(140)
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Book {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(240)
  slug        String    @unique @db.VarChar(260)
  description String
  priceCents  Int
  coverUrl    String?
  publishedAt DateTime?
  isActive    Boolean   @default(true)
  authorId    String    @db.Uuid
  categoryId  String    @db.Uuid
  author      Author    @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([categoryId, isActive])
  @@index([isActive, createdAt(sort: Desc), id], map: "books_active_created_at_id_idx")
  @@index([authorId, isActive, createdAt(sort: Desc), id], map: "books_author_active_created_at_id_idx")
  @@map("books")
}
