{
  "name": "ebookstore",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ebookstore",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=22 <23",
        "npm": ">=10"
      }
    },
    "apps/api": {
      "name": "@ebookstore/api",
      "version": "0.0.0"
    },
    "apps/web": {
      "name": "@ebookstore/web",
      "version": "0.0.0"
    },
    "node_modules/@ebookstore/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@ebookstore/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@ebookstore/eslint-config": {
      "resolved": "packages/eslint-config",
      "link": true
    },
    "node_modules/@ebookstore/test-utils": {
      "resolved": "packages/test-utils",
      "link": true
    },
    "node_modules/@ebookstore/tsconfig": {
      "resolved": "packages/tsconfig",
      "link": true
    },
    "node_modules/@ebookstore/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/contracts": {
      "name": "@ebookstore/contracts",
      "version": "0.0.0"
    },
    "packages/eslint-config": {
      "name": "@ebookstore/eslint-config",
      "version": "0.0.0"
    },
    "packages/test-utils": {
      "name": "@ebookstore/test-utils",
      "version": "0.0.0"
    },
    "packages/tsconfig": {
      "name": "@ebookstore/tsconfig",
      "version": "0.0.0"
    }
  }
}
